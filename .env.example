# ── Azure AI Foundry Project ──
# Your project endpoint from the Foundry portal's Overview page.
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# The default model deployment name from the "Models + endpoints" tab in Foundry.
# Examples: gpt-4o, gpt-4o-mini, gpt-4.1-mini, gpt-5.1, model-router
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o
